// ============================================================================
// USERS & PERMISSIONS
// ============================================================================

model User {
  uid         String   @id @default(uuid())
  username    String   @unique @db.VarChar(100)
  passwordHash String?  @db.VarChar(255) @map("password_hash")
  displayName String?  @db.VarChar(255) @map("display_name")
  photoUrl    String?  @db.VarChar(500) @map("photo_url")
  userType    String?  @default("User") @db.VarChar(50) @map("user_type")
  disabled    Boolean  @default(false)
  creationTime DateTime @default(now()) @map("creation_time")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions      UserPermission[]
  shifts           Shift[]
  posTransactions  PosTransaction[]
  cashTransfers    CashTransfer[]

  @@map("users")
}

model UserPermission {
  id        String   @id @default(uuid())
  userUid   String   @db.VarChar(255) @map("user_uid")
  permission String  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userUid], references: [uid])

  @@unique([userUid, permission])
  @@index([userUid])
  @@index([permission])
  @@map("user_permissions")
}

model UserType {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  permissions UserTypePermission[]

  @@map("user_types")
}

model UserTypePermission {
  id          String   @id @default(uuid())
  userTypeId  String   @db.VarChar(50) @map("user_type_id")
  permission  String   @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")

  userType UserType @relation(fields: [userTypeId], references: [id], onDelete: Cascade)

  @@unique([userTypeId, permission])
  @@map("user_type_permissions")
}

// ============================================================================
// POS - Point of Sale
// ============================================================================

model PosTerminal {
  id                    String   @id @default(uuid())
  name                  String   @db.VarChar(100)
  location              String?  @db.VarChar(255)
  ipAddress             String?  @db.VarChar(45) @map("ip_address")
  serialNumber          String?  @db.VarChar(50) @map("serial_number")
  permitNo              String?  @db.VarChar(50) @map("permit_no")
  terminalMin           String?  @db.VarChar(50) @map("terminal_min")
  terminalSerialNumber  String?  @db.VarChar(50) @map("terminal_serial_number")
  printOfficialReceipt  String?  @db.VarChar(5) @map("print_official_receipt") // Yes|No
  orNextReference       String   @default("00000000") @db.VarChar(50) @map("or_next_reference")
  xCounter              Int      @default(0) @map("x_counter")
  zCounter              Int      @default(0) @map("z_counter")
  resetCounter          Int      @default(0) @map("reset_counter")
  isActive              Boolean  @default(true) @map("is_active")
  lastActive            DateTime? @map("last_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  shifts           Shift[]
  posTransactions  PosTransaction[]
  cashTransfers    CashTransfer[]

  @@map("pos_terminals")
}

model Shift {
  id              String   @id @default(uuid())
  userId          String   @db.VarChar(50) @map("user_id")
  terminalId      String?  @db.VarChar(50) @map("terminal_id")
  startTime       DateTime @map("start_time")
  endTime         DateTime? @map("end_time")
  startingCash    Decimal  @default(0) @db.Decimal(10, 2) @map("starting_cash")
  expectedCash    Decimal  @default(0) @db.Decimal(10, 2) @map("expected_cash")
  actualCash      Decimal  @default(0) @db.Decimal(10, 2) @map("actual_cash")
  cashDifference  Decimal  @default(0) @db.Decimal(10, 2) @map("cash_difference")
  cashDenominations Json?  @map("cash_denominations")
  status          ShiftStatus @default(active)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [uid], onDelete: Cascade)
  terminal         PosTerminal?      @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  posTransactions  PosTransaction[]
  cashTransfers    CashTransfer[]

  @@index([userId])
  @@index([terminalId])
  @@index([status])
  @@index([startTime])
  @@map("shifts")
}

model PosTransaction {
  id                  String   @id @default(uuid())
  saleId              String   @unique @db.VarChar(50) @map("sale_id")
  shiftId             String?  @db.VarChar(50) @map("shift_id")
  userId              String   @db.VarChar(50) @map("user_id")
  terminalId          String?  @db.VarChar(50) @map("terminal_id")
  transactionType     PosTransactionType @default(sale) @map("transaction_type")
  subtotal            Decimal  @db.Decimal(10, 2)
  taxAmount           Decimal  @default(0) @db.Decimal(10, 2) @map("tax_amount")
  discountAmount      Decimal  @default(0) @db.Decimal(10, 2) @map("discount_amount")
  totalAmount         Decimal  @db.Decimal(10, 2) @map("total_amount")
  paymentMethod       String?  @db.VarChar(100) @map("payment_method")
  paymentReference    String?  @db.VarChar(255) @map("payment_reference")
  paymentStatus       String   @default("completed") @db.VarChar(50) @map("payment_status")
  paymentDetailsId    String?  @db.VarChar(50) @map("payment_details_id")
  paymentValidatedAt  DateTime? @map("payment_validated_at")
  customerCount       Int      @default(1) @map("customer_count")
  transactionTime     DateTime @default(now()) @map("transaction_time")
  voidReason          String?  @db.Text @map("void_reason")
  notes               String?  @db.Text
  isTraining          Boolean  @default(false) @map("is_training")
  orderNumber         Int?     @map("order_number")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  sale              SalesTransaction      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  shift             Shift?                @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  user              User                  @relation(fields: [userId], references: [uid], onDelete: Cascade)
  terminal          PosTerminal?          @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  items             PosTransactionItem[]
  paymentDetails    PaymentDetails?       @relation(fields: [paymentDetailsId], references: [id])
  paymentAuditLog   PaymentAuditLog[]

  @@index([saleId])
  @@index([shiftId])
  @@index([userId])
  @@index([terminalId])
  @@index([transactionType])
  @@index([transactionTime])
  @@map("pos_transactions")
}

model PosTransactionItem {
  id                  String   @id @default(uuid())
  posTransactionId    String   @db.VarChar(50) @map("pos_transaction_id")
  saleItemId          String   @db.VarChar(50) @map("sale_item_id")
  productId           String   @db.VarChar(50) @map("product_id")
  productName         String   @db.VarChar(255) @map("product_name")
  quantity            Decimal  @db.Decimal(10, 2)
  unitPrice           Decimal  @db.Decimal(10, 2) @map("unit_price")
  discountPercentage  Decimal  @default(0) @db.Decimal(5, 2) @map("discount_percentage")
  discountAmount      Decimal  @default(0) @db.Decimal(10, 2) @map("discount_amount")
  discountType        String   @default("percent") @db.VarChar(50) @map("discount_type")
  taxType             String   @default("VAT") @db.VarChar(50) @map("tax_type")
  lineTotal           Decimal  @db.Decimal(10, 2) @map("line_total")
  createdAt           DateTime @default(now()) @map("created_at")

  posTransaction PosTransaction @relation(fields: [posTransactionId], references: [id], onDelete: Cascade)
  saleItem       SaleItem       @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([posTransactionId])
  @@index([saleItemId])
  @@index([productId])
  @@map("pos_transaction_items")
}

model PaymentDetails {
  id                  String   @id @default(uuid())
  transactionId       String   @db.VarChar(50) @map("transaction_id")
  paymentMethod       String   @db.VarChar(50) @map("payment_method")
  cardType            String?  @db.VarChar(50) @map("card_type")
  cardLastFour        String?  @db.VarChar(4) @map("card_last_four")
  authCode            String?  @db.VarChar(50) @map("auth_code")
  gatewayReference    String?  @db.VarChar(100) @map("gateway_reference")
  walletProvider      String?  @db.VarChar(50) @map("wallet_provider")
  walletReference     String?  @db.VarChar(100) @map("wallet_reference")
  giftCheckNumber     String?  @db.VarChar(50) @map("gift_check_number")
  giftCheckBalanceBefore Decimal? @db.Decimal(10, 2) @map("gift_check_balance_before")
  giftCheckBalanceAfter  Decimal? @db.Decimal(10, 2) @map("gift_check_balance_after")
  pointsUsed          Decimal? @db.Decimal(10, 2) @map("points_used")
  pointsRemaining     Decimal? @db.Decimal(10, 2) @map("points_remaining")
  pointsConversionRate Decimal? @db.Decimal(10, 4) @map("points_conversion_rate")
  amountTendered      Decimal? @db.Decimal(10, 2) @map("amount_tendered")
  changeGiven         Decimal? @db.Decimal(10, 2) @map("change_given")
  notes               String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  posTransactions PosTransaction[]

  @@index([transactionId])
  @@index([paymentMethod])
  @@index([createdAt])
  @@map("payment_details")
}

model PaymentAuditLog {
  id             String   @id @default(uuid())
  transactionId  String?  @db.VarChar(50) @map("transaction_id")
  paymentMethod  String?  @db.VarChar(50) @map("payment_method")
  action         String   @db.VarChar(50)
  status         String   @db.VarChar(50)
  amount         Decimal? @db.Decimal(10, 2)
  errorMessage   String?  @db.Text @map("error_message")
  details        String?  @db.Text
  userId         String?  @db.VarChar(50) @map("user_id")
  ipAddress      String?  @db.VarChar(45) @map("ip_address")
  userAgent      String?  @db.Text @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  posTransaction PosTransaction? @relation(fields: [transactionId], references: [id])

  @@map("payment_audit_log")
}

model CashTransfer {
  id               String   @id @default(uuid())
  shiftId          String?  @db.VarChar(50) @map("shift_id")
  terminalId       String?  @db.VarChar(50) @map("terminal_id")
  userId           String   @db.VarChar(255) @map("user_id")
  amount           Decimal  @db.Decimal(10, 2)
  type             String   @db.VarChar(50) // deposit | pickup
  reason           String?  @db.Text
  transactionTime  DateTime @default(now()) @map("transaction_time")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  shift    Shift?       @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  terminal PosTerminal? @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  user     User         @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@map("cash_transfers")
}

