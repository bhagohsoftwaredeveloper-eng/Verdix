  maxVoidId       String?  @db.VarChar(50) @map("max_void_id")
  minReturnId     String?  @db.VarChar(50) @map("min_return_id")
  maxReturnId     String?  @db.VarChar(50) @map("max_return_id")
  voidAmount      Decimal  @default(0) @db.Decimal(15, 2) @map("void_amount")
