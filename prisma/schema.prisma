  transactionCount Int     @default(0) @map("transaction_count")
  startingCash    Decimal  @default(0) @db.Decimal(15, 2) @map("starting_cash")
  cashSales       Decimal  @default(0) @db.Decimal(15, 2) @map("cash_sales")
