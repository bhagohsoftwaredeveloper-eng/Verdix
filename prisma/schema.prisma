  discountSummary Json?    @db.JsonB @map("discount_summary")
  salesAdjustment Json?    @db.JsonB @map("sales_adjustment")
  zCounter        Int      @default(0) @map("z_counter")
  resetCounter    Int      @default(0) @map("reset_counter")
  actualCash      Decimal  @default(0) @db.Decimal(15, 2) @map("actual_cash")
  cashDifference  Decimal  @default(0) @db.Decimal(15, 2) @map("cash_difference")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("z_readings")
}

// ============================================================================
// REFERENCE & SETTINGS
// ============================================================================

model TransactionReference {
  id                           Int      @id @default(autoincrement())
  salesOrder                   String?  @db.VarChar(50) @map("sales_order")
  purchaseOrder                String?  @db.VarChar(50) @map("purchase_order")
  salesDelivery                String?  @db.VarChar(50) @map("sales_delivery")
  paymentToSupplier            String?  @db.VarChar(50) @map("payment_to_supplier")
  salesInvoice                 String?  @db.VarChar(50) @map("sales_invoice")
  customerPayment              String?  @db.VarChar(50) @map("customer_payment")
  deliveryReceipt              String?  @db.VarChar(50) @map("delivery_receipt")
  stockAdjustment              String?  @db.VarChar(50) @map("stock_adjustment")
  salesHold                    String?  @db.VarChar(50) @map("sales_hold")
  receiptNumber                String   @default("00000001") @db.VarChar(100) @map("receipt_number")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@map("transaction_references")
}

model TaxRate {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  rate        Decimal  @db.Decimal(5, 2)
  description String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tax_rates")
}

model PriceLevel {
  id                     String   @id @default(uuid())
  name                   String   @unique @db.VarChar(255)
  description            String?  @db.Text
  isDefault              Boolean  @default(false) @map("is_default")
  calculationBase        String?  @db.VarChar(20) @map("calculation_base") // retail | cost
  percentageAdjustment   Decimal? @db.Decimal(10, 2) @map("percentage_adjustment")
  minQuantity            Int?     @map("min_quantity")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  productPriceLevels ProductPriceLevel[]

  @@map("price_levels")
}

model ProductPriceLevel {
  id           String   @id @default(uuid())
  productId    String   @db.VarChar(50) @map("product_id")
  priceLevelId String   @db.VarChar(50) @map("price_level_id")
  price        Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceLevel  PriceLevel @relation(fields: [priceLevelId], references: [id], onDelete: Cascade)

  @@unique([productId, priceLevelId])
  @@index([productId])
  @@index([priceLevelId])
  @@map("product_price_levels")
}

model SalesPerson {
  id            String   @id @default(uuid())
  name          String   @unique @db.VarChar(255)
  contactNumber String?  @db.VarChar(50) @map("contact_number")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("sales_persons")
}

model SalesArea {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(255)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sales_areas")
}

model SalesGroup {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(255)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sales_groups")
}

model PaymentTerm {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  days      Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payment_terms")
}

model PaymentTermType {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("payment_term_types")
}

// ============================================================================
// POS SETTINGS
// ============================================================================

model PosSettings {
  id                              String   @id @default(uuid())
  businessName                    String   @db.VarChar(255) @map("business_name")
  operatedBy                      String?  @db.VarChar(255) @map("operated_by")
  address                         String?  @db.VarChar(500)
  contactNumber                   String?  @db.VarChar(100) @map("contact_number")
  tin                             String?  @db.VarChar(50)
  email                           String?  @db.VarChar(255)
  minNumber                       String?  @db.VarChar(50) @map("min_number")
  serialNumber                    String?  @db.VarChar(50) @map("serial_number")
  logoPath                        String?  @db.VarChar(500) @map("logo_path")
  printMode                       PrintMode @default(browser) @map("print_mode")
  currencySymbol                  String?  @db.VarChar(10) @map("currency_symbol")
  currencyCode                    String?  @db.VarChar(10) @map("currency_code")
  timezone                        String?  @db.VarChar(100)
  dateFormat                      String?  @db.VarChar(50) @map("date_format")
  enableAutomaticMarkup           Boolean  @default(false) @map("enable_automatic_markup")
  defaultMarkupPercentage         Decimal? @db.Decimal(10, 2) @map("default_markup_percentage")
  markupPriority                  Json?    @db.JsonB @map("markup_priority")
  enablePriceEditAuth             Boolean? @map("enable_price_edit_auth")
  priceEditAuthUsername           String?  @db.VarChar(100) @map("price_edit_auth_username")
  priceEditAuthPassword           String?  @db.VarChar(255) @map("price_edit_auth_password")
  enableRecentSalesAuth           Boolean  @default(false) @map("enable_recent_sales_auth")
  recentSalesAuthUsername         String?  @db.VarChar(100) @map("recent_sales_auth_username")
  recentSalesAuthPassword         String?  @db.VarChar(255) @map("recent_sales_auth_password")
  enableLineVoidAuth              Boolean? @map("enable_line_void_auth")
  lineVoidAuthUsername            String?  @db.VarChar(100) @map("line_void_auth_username")
  lineVoidAuthPassword            String?  @db.VarChar(255) @map("line_void_auth_password")
  enableVoidReturnAuth            Boolean  @default(false) @map("enable_void_return_auth")
  voidAuthUsername                String?  @db.VarChar(100) @map("void_auth_username")
  voidAuthPassword                String?  @db.VarChar(255) @map("void_auth_password")
  printTwoReceipts                Boolean? @map("print_two_receipts")
  nativePrinterName               String?  @db.VarChar(255) @map("native_printer_name")
  paperSize                       PaperSize @default(mm80) @map("paper_size")
  requireAdjustmentConfirmation   Boolean? @map("require_adjustment_confirmation")
  requireTransferConfirmation     Boolean? @map("require_transfer_confirmation")
  requirePurchaseOrderConfirmation Boolean? @map("require_purchase_order_confirmation")
  requireReceiveConfirmation      Boolean? @map("require_receive_confirmation")
  requireBadOrderConfirmation     Boolean? @map("require_bad_order_confirmation")
  requireStockCountApproval       Boolean? @map("require_stock_count_approval")
  enableOverallReadingAuth        Boolean? @map("enable_overall_reading_auth")
  overallReadingAuthUsername      String?  @db.VarChar(100) @map("overall_reading_auth_username")
  overallReadingAuthPassword      String?  @db.VarChar(255) @map("overall_reading_auth_password")
  showQuantity                    Boolean? @map("show_quantity")
  isTrainingMode                  Boolean  @default(false) @map("is_training_mode")
  lastEjournalExport              DateTime? @map("last_ejournal_export")
  batchCostingRepackInherit       Boolean  @default(true) @map("batch_costing_repack_inherit")
  batchCostingOversellBlock       Boolean  @default(false) @map("batch_costing_oversell_block")
  transactionPrefix               String   @default("TXN") @db.VarChar(20) @map("transaction_prefix")
  enableAdvancedInventory         Boolean  @default(false) @map("enable_advanced_inventory")
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")

  @@map("pos_settings")
}

// ============================================================================
// APPROVAL SYSTEM
// ============================================================================

model ApprovalWorkflow {
  id               String   @id @default(uuid())
  transactionType  String   @db.VarChar(50) @map("transaction_type")
  userTypeId       String   @db.VarChar(36) @map("user_type_id")
  stepOrder        Int      @map("step_order")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("approval_workflows")
}

model ApprovalQueue {
  id               String   @id @default(uuid())
  transactionType  String   @db.VarChar(50) @map("transaction_type")
  transactionData  Json     @db.JsonB @map("transaction_data")
  status           ApprovalStatus @default(Pending)
  currentStep      Int      @default(1) @map("current_step")
  createdById      String   @db.VarChar(36) @map("created_by")
  customerId       String?  @db.VarChar(50) @map("customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  history          ApprovalHistory[]
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([transactionType])
  @@index([status])
  @@index([status, transactionType])
  @@map("approval_queue")
}

model ApprovalHistory {
  id               String   @id @default(uuid())
  approvalQueueId  String   @db.VarChar(36) @map("approval_queue_id")
  userId           String   @db.VarChar(36) @map("user_id")
  action           ApprovalAction
  notes            String?  @db.Text
  stepNumber       Int      @map("step_number")
  createdAt        DateTime @default(now()) @map("created_at")

  approvalQueue ApprovalQueue @relation(fields: [approvalQueueId], references: [id], onDelete: Cascade)

  @@map("approval_history")
}

model ExternalApiSettings {
  id           Int      @id @default(autoincrement())
  settingKey   String   @unique @map("setting_key") @db.VarChar(100)
  settingValue String?  @map("setting_value") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("external_api_settings")
}

model ExternalApiLog {
  id              String   @id @default(uuid())
  transactionType String   @map("transaction_type") @db.VarChar(100)
  transactionId   String   @map("transaction_id") @db.VarChar(100)
  endpoint        String   @db.VarChar(500)
  payload         String   @db.Text
  response        String?  @db.Text
  status          String   @db.VarChar(50) // success | failed | pending
  errorMessage    String?  @map("error_message") @db.Text
  retryCount      Int      @default(0) @map("retry_count")
  nextRetryAt     DateTime? @map("next_retry_at")
  lastRetryAt     DateTime? @map("last_retry_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([transactionType])
  @@index([transactionId])
  @@index([status])
  @@map("external_api_logs")
}
