  returns         Decimal  @default(0) @db.Decimal(15, 2)
  discounts       Decimal  @default(0) @db.Decimal(15, 2)
  netSales        Decimal  @default(0) @db.Decimal(15, 2) @map("net_sales")
  vatSales        Decimal  @default(0) @db.Decimal(15, 2) @map("vat_sales")
  vatAmount       Decimal  @default(0) @db.Decimal(15, 2) @map("vat_amount")
