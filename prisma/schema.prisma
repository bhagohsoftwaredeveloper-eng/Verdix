// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum SaleStatus {
  Paid
  Pending
  Failed
  Shipped
  Delivered
  Returned
  Voided
  ToDeliver
  FullyDelivered
  PartiallyPaid
}

enum ShiftStatus {
  active
  completed
  reconciled
}

enum PosTransactionType {
  sale
  void
  return
  refund
}

enum StockMovementType {
  sale
  purchase
  adjustment
  return
  transfer
  repackaging
}

enum StockAdjustmentType {
  add
  remove
  transfer
}

enum PurchaseOrderStatus {
  Pending
  Approved
  Paid
  Shipped
  Received
  Failed
  PartiallyPaid
}

enum BadOrderStatus {
  Reported
  ReturnRequested
  Replaced
  Credited
  Resolved
}

enum BadOrderItemReason {
  Damaged
  Defective
  Expired
  WrongItem
  Missing
  Other
}

enum PointTransactionType {
  add
  remove
  purchase
  redemption
  expiration
  adjustment
}

enum ApprovalStatus {
  Pending
  Approved
  Rejected
}

enum ApprovalAction {
  Approve
  Reject
}

enum TransactionReferenceType {
  sales_order
  purchase_order
  sales_delivery
  payment_to_supplier
  sales_invoice
  customer_payment
  delivery_receipt
  stock_adjustment
  sales_hold
}

enum PrintMode {
  browser
  escpos
  usb
}

enum PaperSize {
  mm58
  mm80
}

enum TransferStatus {
  Pending
  Completed
  Cancelled
}

enum StockCountStatus {
  in_progress
  completed
  cancelled
}

enum PointTransactionStatus {
  completed
  failed
  pending
}

enum RepackagingStatus {
  pending
  completed
  cancelled
}

// ============================================================================
// CATALOG - Products & Categories
// ============================================================================

model Product {
  id                    String   @id @default(uuid())
  name                  String   @db.VarChar(255)
  description           String?  @db.Text
  additionalDescription String?  @db.Text @map("additional_description")
  category              String?  @db.VarChar(100)
  brand                 String?  @db.VarChar(100)
  department            String?  @db.VarChar(255)
  subcategory           String?  @db.VarChar(100)
  stock                 Decimal  @default(0) @db.Decimal(15, 4)
  reorderPoint          Decimal  @default(0) @db.Decimal(15, 4) @map("reorder_point")
  avgDailySales         Decimal  @default(0) @db.Decimal(10, 2) @map("avg_daily_sales")
  price                 Decimal  @db.Decimal(10, 2)
  cost                  Decimal? @db.Decimal(10, 2)
  sku                   String?  @unique @db.VarChar(100)
  barcode               String?  @db.VarChar(100)
  imageUrl              String?  @db.VarChar(500) @map("image_url")
  imageHint             String?  @db.VarChar(255) @map("image_hint")
  unitOfMeasure         String?  @db.VarChar(50) @map("unit_of_measure")
  vatStatus             String?  @db.VarChar(50) @map("vat_status")
  availability          String?  @db.VarChar(50)
  taxType               String?  @db.VarChar(50) @map("tax_type")
  earnsPoints           Boolean  @default(true) @map("earns_points")
  expirationDate        DateTime? @db.Date @map("expiration_date")
  parentId              String?  @db.VarChar(50) @map("parent_id")
  incomeAccount         String?  @db.VarChar(50) @map("income_account")
  expenseAccount        String?  @db.VarChar(50) @map("expense_account")
  supplierId            String?  @db.VarChar(50) @map("supplier_id")
  warehouseId           String?  @db.VarChar(50) @map("warehouse_id")
  shelfLocationId       String?  @db.VarChar(50) @map("shelf_location_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  saleItems             SaleItem[]
  salesInvoiceItems     SalesInvoiceItem[]
  salesOrderItems       SalesOrderItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  badOrderItems         BadOrderItem[]
  stockAdjustments      StockAdjustment[]
  stockMovements        StockMovement[]
  stockCountItems       StockCountItem[]
  inventoryBatches      InventoryBatch[]
  inventoryTransferItems InventoryTransferItem[]
  repackagingLogsSource RepackagingLog[] @relation("source_product")
  repackagingLogsTarget RepackagingLog[] @relation("target_product")
  conversionFactors     ConversionFactor[]
  supplierMappings      SupplierProductMapping[]
  productShelves        ProductShelf[]
  posTransactionItems   PosTransactionItem[]
  productPriceLevels    ProductPriceLevel[]

  @@index([sku])
  @@index([category])
  @@index([supplierId])
  @@index([warehouseId])
  @@map("products")
}

model Category {
  id                  String   @id @default(uuid())
  name                String   @unique @db.VarChar(100)
  markupPercentage    Decimal  @default(0) @db.Decimal(10, 2) @map("markup_percentage")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model Subcategory {
  id                  String   @id @default(uuid())
  name                String   @unique @db.VarChar(100)
  markupPercentage    Decimal  @default(0) @db.Decimal(10, 2) @map("markup_percentage")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("subcategories")
}

model Brand {
  id                  String   @id @default(uuid())
  name                String   @unique @db.VarChar(100)
  markupPercentage    Decimal  @default(0) @db.Decimal(10, 2) @map("markup_percentage")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("brands")
}

model Department {
  id                  String   @id @default(uuid())
  name                String   @unique @db.VarChar(255)
  markupPercentage    Decimal  @default(0) @db.Decimal(10, 2) @map("markup_percentage")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("departments")
}

model UnitOfMeasure {
  id            String   @id @default(uuid())
  name          String   @unique @db.VarChar(100)
  abbreviation  String?  @db.VarChar(10)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("units_of_measure")
}

model ConversionFactor {
  id        String   @id @default(uuid())
  productId String   @db.VarChar(50) @map("product_id")
  unit      String   @db.VarChar(100)
  factor    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, unit])
  @@index([productId])
  @@map("conversion_factors")
}

model Account {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(255)
  type      String   @db.VarChar(50) // income | expense
  code      String?  @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("accounts")
}

// ============================================================================
// SUPPLIERS
// ============================================================================

model Supplier {
  id                  String   @id @default(uuid())
  name                String   @unique @db.VarChar(255)
  contactNumber       String?  @db.VarChar(20) @map("contact_number")
  telephone           String?  @db.VarChar(50)
  mobilePhone         String?  @db.VarChar(50) @map("mobile_phone")
  email               String?  @db.VarChar(255)
  address             String?  @db.Text
  company             String?  @db.VarChar(255)
  tin                 String?  @db.VarChar(50)
  paymentTerms        String?  @db.VarChar(100) @map("payment_terms")
  markupPercentage    Decimal  @default(0) @db.Decimal(5, 2) @map("markup_percentage")
  orderSchedule       String?  @db.VarChar(255) @map("order_schedule")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  productMappings     SupplierProductMapping[]
  payments            SupplierPayment[]
  purchaseOrders      PurchaseOrder[]
  badOrders           BadOrder[]

  @@map("suppliers")
}

model SupplierProductMapping {
  id                  String   @id @default(uuid())
  productId           String   @db.VarChar(50) @map("product_id")
  supplierId          String   @db.VarChar(50) @map("supplier_id")
  supplierSku         String?  @db.VarChar(100) @map("supplier_sku")
  supplierLeadTime    Int      @default(0) @map("supplier_lead_time")
  supplierSpecificRop Int      @default(0) @map("supplier_specific_rop")
  supplierCost        Decimal? @db.Decimal(10, 2) @map("supplier_cost")
  isPrimary           Boolean  @default(false) @map("is_primary")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier  Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@index([productId])
  @@index([supplierId])
  @@map("supplier_product_mapping")
}

model SupplierPayment {
  id            String   @id @default(uuid())
  supplierId    String   @db.VarChar(50) @map("supplier_id")
  amount        Decimal  @db.Decimal(10, 2)
  date          DateTime @map("date")
  paymentMethod String?  @db.VarChar(100) @map("payment_method")
  reference     String?  @db.VarChar(100)
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  supplier  Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@map("supplier_payments")
}

// ============================================================================
// CUSTOMERS & LOYALTY
// ============================================================================

model Customer {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(255)
  contactNumber   String?  @db.VarChar(50) @map("contact_number")
  active          Boolean  @default(true)
  salesPerson     String?  @db.VarChar(255) @map("sales_person")
  salesArea       String?  @db.VarChar(255) @map("sales_area")
  salesGroup      String?  @db.VarChar(255) @map("sales_group")
  paymentTerms    String?  @db.VarChar(100) @map("payment_terms")
  loyaltyPoints   Decimal  @default(0) @db.Decimal(15, 4) @map("loyalty_points")
  address         String?  @db.Text
  billingAddress  String?  @db.Text @map("billing_address")
  discount        Decimal  @default(0) @db.Decimal(5, 2)
  creditLimit     Decimal  @default(0) @db.Decimal(15, 2) @map("credit_limit")
  priceLevelId    String?  @db.VarChar(50) @map("price_level_id")
  tin             String?  @db.VarChar(50)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  loyalty              CustomerLoyalty?
  payments             CustomerPayment[]
  salesInvoices        SalesInvoice[]
  salesOrders          SalesOrder[]
  salesTransactions    SalesTransaction[]
  approvalQueues       ApprovalQueue[]

  @@index([name])
  @@index([contactNumber])
  @@map("customers")
}

model CustomerLoyalty {
  id               String   @id @default(uuid())
  customerId       String   @unique @db.VarChar(50) @map("customer_id")
  rfidCode         String?  @unique @db.VarChar(100) @map("rfid_code")
  expiryDate       DateTime? @db.Date @map("expiry_date")
  pointSetting     String?  @db.VarChar(100) @map("point_setting")
  currentPoints    Decimal  @default(0) @db.Decimal(15, 4) @map("current_points")
  lastTransaction  DateTime? @map("last_transaction")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pointHistory   PointHistory[]

  @@index([customerId])
  @@index([rfidCode])
  @@index([expiryDate])
  @@map("customer_loyalty")
}

model PointHistory {
  id                    String   @id @default(uuid())
  customerLoyaltyId     String   @db.VarChar(50) @map("customer_loyalty_id")
  transactionType       PointTransactionType @map("transaction_type")
  points                Decimal  @db.Decimal(15, 4)
  reason                String?  @db.VarChar(255)
  transactionReference  String?  @db.VarChar(100) @map("transaction_reference")
  createdBy             String?  @db.VarChar(50) @map("created_by")
  createdAt             DateTime @default(now()) @map("created_at")

  customerLoyalty CustomerLoyalty @relation(fields: [customerLoyaltyId], references: [id], onDelete: Cascade)

  @@index([customerLoyaltyId])
  @@index([transactionType])
  @@index([createdAt])
  @@map("point_history")
}

model LoyaltyPointsSetting {
  id         String   @id @default(uuid())
  description String  @db.VarChar(255)
  base       Decimal  @default(0) @db.Decimal(10, 2)
  amount     Decimal  @default(0) @db.Decimal(10, 2)
  equivalent Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("loyalty_points_settings")
}

model CustomerPayment {
  id            String   @id @default(uuid())
  customerId    String   @db.VarChar(255) @map("customer_id")
  paymentType   String   @db.VarChar(100) @map("payment_type")
  paymentDate   DateTime @map("payment_date")
  amount        Decimal  @db.Decimal(10, 2)
  reference     String   @unique @db.VarChar(100)
  note          String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([paymentDate])
  @@index([reference])
  @@map("customer_payments")
}

// ============================================================================
// SALES - Transactions, Invoices, Orders
// ============================================================================

model SalesTransaction {
  id                  String   @id @default(uuid())
  reference           String?  @db.VarChar(100)
  receiptNumber       String?  @db.VarChar(100) @map("receipt_number")
  customerId          String?  @db.VarChar(50) @map("customer_id")
  invoiceDate         DateTime? @db.Date @map("invoice_date")
  date                DateTime? @db.Date
  dueDate             DateTime? @db.Date @map("due_date")
  total               Decimal  @db.Decimal(10, 2)
  paymentMethod       String?  @db.VarChar(100) @map("payment_method")
  paymentReference    String?  @db.VarChar(255) @map("payment_reference")
  status              SaleStatus @default(Pending)
  transactionSource   String?  @db.VarChar(50) @map("transaction_source") // POS | Backoffice
  notes               String?  @db.Text
  orderNumber         Int?     @map("order_number")
  isTraining          Boolean  @default(false) @map("is_training")
  warehouseId         String?  @db.VarChar(50) @map("warehouse_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  customer            Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items               SaleItem[]
  posTransaction      PosTransaction?

  @@index([customerId])
  @@index([date])
  @@index([invoiceDate])
  @@index([status])
  @@index([paymentMethod])
  @@map("sales_transactions")
}

model SaleItem {
  id           String   @id @default(uuid())
  saleId       String   @db.VarChar(50) @map("sale_id")
  productId    String   @db.VarChar(50) @map("product_id")
  productName  String   @db.VarChar(255) @map("product_name")
  quantity     Int
  price        Decimal  @db.Decimal(10, 2)
  costAtSale   Decimal? @db.Decimal(14, 4) @map("cost_at_sale")
  batchSource  Json?    @db.JsonB @map("batch_source")
  createdAt    DateTime @default(now()) @map("created_at")

  sale         SalesTransaction @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product      Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  posTransactionItems PosTransactionItem[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model SalesInvoice {
  id                  String   @id @default(uuid())
  reference           String?  @db.VarChar(100)
  receiptNumber       String?  @db.VarChar(100) @map("receipt_number")
  customerId          String   @db.VarChar(50) @map("customer_id")
  invoiceDate         DateTime @db.Date @map("invoice_date")
  dueDate             DateTime? @db.Date @map("due_date")
  total               Decimal  @db.Decimal(10, 2)
  paymentMethod       String?  @db.VarChar(100) @map("payment_method")
  paymentReference    String?  @db.VarChar(255) @map("payment_reference")
  status              SaleStatus @default(Pending)
  transactionSource   String?  @db.VarChar(50) @map("transaction_source")
  salesPersonId       String?  @db.VarChar(50) @map("sales_person_id")
  notes               String?  @db.Text
  amountPaid          Decimal? @db.Decimal(10, 2) @map("amount_paid")
  shipping            Decimal? @db.Decimal(10, 2)
  isTraining          Boolean  @default(false) @map("is_training")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  customer  Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items     SalesInvoiceItem[]

  @@index([customerId])
  @@index([invoiceDate])
  @@index([dueDate])
  @@index([status])
  @@index([paymentMethod])
  @@map("sales_invoices")
}

model SalesInvoiceItem {
  id              String   @id @default(uuid())
  salesInvoiceId  String   @db.VarChar(50) @map("sales_invoice_id")
  productId       String   @db.VarChar(50) @map("product_id")
  productName     String   @db.VarChar(255) @map("product_name")
  quantity        Int
  price           Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([salesInvoiceId])
  @@index([productId])
  @@map("sales_invoice_items")
}

model SalesOrder {
  id              String   @id @default(uuid())
  customerId      String   @db.VarChar(50) @map("customer_id")
  orderDate       DateTime @db.Date @map("order_date")
  deliveryDate    DateTime? @db.Date @map("delivery_date")
  reference       String?  @db.VarChar(100)
  deliveryAddress String?  @db.Text @map("delivery_address")
  total           Decimal  @default(0) @db.Decimal(10, 2)
  paymentMethod   String?  @db.VarChar(100) @map("payment_method")
  status          SaleStatus @default(Pending)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer  Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items     SalesOrderItem[]

  @@map("sales_orders")
}

model SalesOrderItem {
  id            String   @id @default(uuid())
  salesOrderId  String   @db.VarChar(50) @map("sales_order_id")
  productId     String   @db.VarChar(50) @map("product_id")
  productName   String   @db.VarChar(255) @map("product_name")
  quantity      Int
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("sales_order_items")
}

model PaymentMethod {
  id                   String   @id @default(uuid())
  name                 String   @unique @db.VarChar(100)
  isActive             Boolean  @default(true) @map("is_active")
  isReferenceRequired  Boolean  @default(false) @map("is_reference_required")
  pointsAmount         Decimal? @db.Decimal(10, 2) @map("points_amount")
  currencyEquivalent   Decimal? @db.Decimal(10, 2) @map("currency_equivalent")
  createdAt            DateTime @default(now()) @map("created_at")

  @@map("payment_methods")
}

// ============================================================================
// PURCHASE ORDERS
// ============================================================================

model PurchaseOrder {
  id               String   @id @default(uuid())
  supplierId       String   @db.VarChar(50) @map("supplier_id")
  supplierName     String   @db.VarChar(255) @map("supplier_name")
  orderedBy        String?  @db.VarChar(255) @map("ordered_by")
  date             DateTime @map("date")
  deliveryDate     DateTime? @map("delivery_date")
  total            Decimal  @default(0) @db.Decimal(10, 2)
  shippingFee      Decimal  @default(0) @db.Decimal(10, 2) @map("shipping_fee")
  vatAmount        Decimal  @default(0) @db.Decimal(10, 2) @map("vat_amount")
  receivedTotal    Decimal  @default(0) @db.Decimal(10, 2) @map("received_total")
  paymentMethod    String?  @db.VarChar(100) @map("payment_method")
  paidAmount       Decimal  @default(0) @db.Decimal(10, 2) @map("paid_amount")
  status           PurchaseOrderStatus @default(Pending)
  referenceNumber  String?  @db.VarChar(100) @map("reference_number")
  warehouseId      String?  @db.VarChar(50) @map("warehouse_id")
  warehouseName    String?  @db.VarChar(255) @map("warehouse_name")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  supplier          Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items             PurchaseOrderItem[]
  badOrders         BadOrder[]

  @@index([supplierId])
  @@index([date])
  @@index([status])
  @@index([paymentMethod])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String   @db.VarChar(50) @map("purchase_order_id")
  productId       String   @db.VarChar(50) @map("product_id")
  productName     String   @db.VarChar(255) @map("product_name")
  quantity        Int
  cost            Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal? @db.Decimal(10, 2) @map("selling_price")
  discount        Decimal  @default(0) @db.Decimal(10, 2)
  discountType    String   @default("amount") @db.VarChar(20) @map("discount_type")
  vatSubject      Boolean  @default(false) @map("vat_subject")
  subtotal        Decimal? @db.Decimal(10, 2)
  expirationDate  DateTime? @db.Date @map("expiration_date")
  barcode         String?  @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

model BadOrder {
  id                   String   @id @default(uuid())
  purchaseOrderId      String   @db.VarChar(50) @map("purchase_order_id")
  supplierId           String   @db.VarChar(50) @map("supplier_id")
  supplierName         String   @db.VarChar(255) @map("supplier_name")
  reportedBy           String?  @db.VarChar(255) @map("reported_by")
  reportDate           DateTime @map("report_date")
  status               BadOrderStatus @default(Reported)
  totalAffectedValue   Decimal  @default(0) @db.Decimal(10, 2) @map("total_affected_value")
  notes                String?  @db.Text
  resolutionNotes      String?  @db.Text @map("resolution_notes")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items         BadOrderItem[]

  @@map("bad_orders")
}

model BadOrderItem {
  id          String   @id @default(uuid())
  badOrderId  String   @db.VarChar(50) @map("bad_order_id")
  productId   String   @db.VarChar(50) @map("product_id")
  productName String   @db.VarChar(255) @map("product_name")
  quantity    Decimal  @db.Decimal(10, 2)
  cost        Decimal  @db.Decimal(10, 2)
  reason      BadOrderItemReason
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  badOrder BadOrder @relation(fields: [badOrderId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("bad_order_items")
}

// ============================================================================
// INVENTORY
// ============================================================================

model StockAdjustment {
  id                 String   @id @default(uuid())
  productId          String   @db.VarChar(50) @map("product_id")
  quantity           Decimal  @db.Decimal(15, 4)
  reason             String   @db.VarChar(255)
  newStock           Decimal  @db.Decimal(15, 4) @map("new_stock")
  status             String?  @db.VarChar(50) // Pending|Approved|Rejected|Completed
  date               DateTime? @db.Date
  warehouseId        String?  @db.VarChar(50) @map("warehouse_id")
  targetWarehouseId  String?  @db.VarChar(50) @map("target_warehouse_id")
  referenceNo        String?  @db.VarChar(100) @map("reference_no")
  supplierId         String?  @db.VarChar(50) @map("supplier_id")
  note               String?  @db.Text
  adjType            StockAdjustmentType @default(add) @map("adj_type")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@map("stock_adjustments")
}

model StockMovement {
  id             String   @id @default(uuid())
  productId      String   @db.VarChar(50) @map("product_id")
  productName    String   @db.VarChar(255) @map("product_name")
  movementType   StockMovementType @map("movement_type")
  quantityChange Decimal  @db.Decimal(15, 4) @map("quantity_change")
  previousStock  Decimal  @db.Decimal(15, 4) @map("previous_stock")
  newStock       Decimal  @db.Decimal(15, 4) @map("new_stock")
  referenceId    String?  @db.VarChar(50) @map("reference_id")
  referenceType  String?  @db.VarChar(50) @map("reference_type")
  warehouseId    String?  @db.VarChar(50) @map("warehouse_id")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([movementType])
  @@index([referenceId])
  @@index([createdAt])
  @@map("stock_movements")
}

model StockCount {
  id          String   @id @default(uuid())
  status      StockCountStatus @default(in_progress)
  name        String   @db.VarChar(255)
  notes       String?  @db.Text
  createdBy   String?  @db.VarChar(50) @map("created_by")
  completedBy String?  @db.VarChar(50) @map("completed_by")
  completedAt DateTime? @map("completed_at")
  warehouseId String?  @db.VarChar(50) @map("warehouse_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items StockCountItem[]

  @@map("stock_counts")
}

model StockCountItem {
  id               String   @id @default(uuid())
  stockCountId     String   @db.VarChar(50) @map("stock_count_id")
  productId        String   @db.VarChar(50) @map("product_id")
  snapshotQuantity Int      @map("snapshot_quantity")
  countedQuantity  Int?     @map("counted_quantity")
  variance         Int?
  shelfLocationId  String?  @db.VarChar(50) @map("shelf_location_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_count_items")
}

model InventoryBatch {
  id                String   @id @default(uuid())
  productId         String   @db.VarChar(50) @map("product_id")
  purchaseOrderId   String?  @db.VarChar(50) @map("purchase_order_id")
  receivedDate      DateTime @db.Date @map("received_date")
  quantityIn        Decimal  @db.Decimal(14, 4) @map("quantity_in")
  quantityRemaining Decimal  @db.Decimal(14, 4) @map("quantity_remaining")
  unitCost          Decimal  @db.Decimal(14, 4) @map("unit_cost")
  sellingPrice      Decimal  @db.Decimal(10, 2) @map("selling_price")
  sourceType        String   @default("purchase") @db.VarChar(30) @map("source_type")
  notes             String?  @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([purchaseOrderId])
  @@index([receivedDate])
  @@map("inventory_batches")
}

model InventoryTransfer {
  id                 String   @id @default(uuid())
  sourceWarehouseId  String   @db.VarChar(50) @map("source_warehouse_id")
  targetWarehouseId  String   @db.VarChar(50) @map("target_warehouse_id")
  transferDate       DateTime @map("transfer_date")
  reference          String?  @db.VarChar(100)
  status             TransferStatus @default(Completed)
  notes              String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  items InventoryTransferItem[]

  @@map("inventory_transfers")
}

model InventoryTransferItem {
  id         String   @id @default(uuid())
  transferId String   @db.VarChar(50) @map("transfer_id")
  productId  String   @db.VarChar(50) @map("product_id")
  productName String  @db.VarChar(255) @map("product_name")
  quantity   Decimal  @db.Decimal(15, 4)
  unitOfMeasure String? @db.VarChar(50) @map("unit_of_measure")
  createdAt  DateTime @default(now()) @map("created_at")

  transfer InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory_transfer_items")
}

model RepackagingLog {
  id               String   @id @default(uuid())
  sourceProductId  String   @db.VarChar(100) @map("source_product_id")
  sourceProductName String  @db.VarChar(255) @map("source_product_name")
  sourceQty        Decimal  @db.Decimal(15, 4) @map("source_qty")
  targetProductId  String   @db.VarChar(100) @map("target_product_id")
  targetProductName String  @db.VarChar(255) @map("target_product_name")
  targetQtyProduced Decimal @db.Decimal(15, 4) @map("target_qty_produced")
  factor           Decimal  @db.Decimal(15, 4)
  status           RepackagingStatus @default(pending)
  approvalQueueId  String?  @db.VarChar(100) @map("approval_queue_id")
  notes            String?  @db.Text
  createdBy        String?  @db.VarChar(100) @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  sourceProduct Product @relation("source_product", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct Product @relation("target_product", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@index([sourceProductId])
  @@index([targetProductId])
  @@map("repackaging_logs")
}

// ============================================================================
// WAREHOUSES & LOCATIONS
// ============================================================================

model Warehouse {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(255)
  location  String?  @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("warehouses")
}

model ShelfLocation {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(255)
  description String? @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productShelves ProductShelf[]

  @@map("shelf_locations")
}

model ProductShelf {
  productId String   @db.VarChar(50) @map("product_id")
  shelfId   String   @db.VarChar(50) @map("shelf_id")
  quantity  Decimal  @default(0) @db.Decimal(15, 4)

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  shelf   ShelfLocation @relation(fields: [shelfId], references: [id], onDelete: Cascade)

  @@id([productId, shelfId])
  @@map("product_shelves")
