# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/.next-test/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.genkit/*
.env*

# firebase
firebase-debug.log
firestore-debug.log

# Large files and build outputs
/vendor/
/Output/
/dist/

# Backups and logs
/backups/
/scratch/
*.log
DB_BACK_UP5112026.sql

# Licensing — signing keys & installed license must never be committed
/license-server/keys/
/license-generator/keys/
license.dat
*.license
