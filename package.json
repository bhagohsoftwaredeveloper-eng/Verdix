{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "migrate": "tsx scripts/migrations/index.ts up",
    "migrate:down": "tsx scripts/migrations/index.ts down",
    "set-admin": "tsx scripts/set-super-admin.ts",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000/pos && node start-electron.js --route=/pos --role=\"POS Terminal\"\"",
    "electron-only": "node start-electron.js --route=/pos --role=\"POS Terminal\"",
    "electron-admin-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000/dashboard && node start-electron.js --route=/dashboard --role=\"Admin Dashboard\"\"",
    "electron-admin": "node start-electron.js --route=/dashboard --role=\"Admin Dashboard\"",
    "dist": "electron-builder --win",
    "build:installer": "iscc setup.iss"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^4.1.3",
    "@point-of-sale/receipt-printer-encoder": "^3.0.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "esc-pos-encoder": "^3.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "koffi": "^2.15.1",
    "lucide-react": "^0.562.0",
    "mysql2": "^3.15.3",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "papaparse": "^5.5.3",
    "patch-package": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-to-print": "^3.2.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.16.2",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.stockpilot.pos",
    "productName": "Stock Pilot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup_portable_db.js",
      "printer-sdk.js",
      "epson-sdk.js",
      "package.json",
      "public/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "public/Stockpilot.png"
    }
  }
}
